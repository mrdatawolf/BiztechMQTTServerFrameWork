# ─── Identity ────────────────────────────────────────────────────────────────
# Leave blank to auto-generate on first run. Values are written back to .env.
PROJECT_ID=
SYSTEM_ID=

# Human-readable name for this location, used in connection-pool messages
# (see "connectionTests" in checks.json) so other locations' results can be
# told apart. Falls back to SYSTEM_ID if left blank.
LOCATION_LABEL=

# ─── MQTT Broker ─────────────────────────────────────────────────────────────
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# ─── Heartbeat ───────────────────────────────────────────────────────────────
# Cron expression for how often the server publishes its heartbeat.
# Default: every minute. Alert clients watch this topic for server liveness.
HEARTBEAT_CRON=*/1 * * * *

# ─── History ─────────────────────────────────────────────────────────────────
# Local SQLite audit log of all check results. Created automatically.
HISTORY_DB_PATH=data/history.db
